{
  "expo": {
    "name": "Academic Task Manager",
    "slug": "academic-task-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "backgroundColor": "#0b0b14",
      "package": "com.jerukpurutt.academictaskmanager",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#0b0b14"
      }
    },
    "extra": {
      "eas": {
        "projectId": "aa57c8bc-b4d4-4250-80bd-59f4eeed50a2"
      }
    }
  }
}
